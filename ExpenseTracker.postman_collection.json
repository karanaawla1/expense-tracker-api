{
  "info": {
    "name": "Expense Tracker API",
    "_postman_id": "expense-tracker-karan-2024",
    "description": "Complete REST API collection for Expense Tracker App built with Python Flask",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Karan Aawla\",\n  \"email\": \"karan@example.com\",\n  \"password\": \"Test@123\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"karan@example.com\",\n  \"password\": \"Test@123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/categories/"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": "{{BASE_URL}}/api/categories/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Food\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": "{{BASE_URL}}/api/categories/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Groceries\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/categories/1"
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Get All Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/expenses/"
          }
        },
        {
          "name": "Get Expenses by Category (Filter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/expenses/?category_id=1",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "expenses", ""],
              "query": [{ "key": "category_id", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Expenses by Date Range (Filter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/expenses/?start_date=2024-03-01&end_date=2024-03-31",
              "query": [
                { "key": "start_date", "value": "2024-03-01" },
                { "key": "end_date", "value": "2024-03-31" }
              ]
            }
          }
        },
        {
          "name": "Get Single Expense",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/expenses/1"
          }
        },
        {
          "name": "Add Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": "{{BASE_URL}}/api/expenses/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Swiggy Order\",\n  \"amount\": 250.00,\n  \"description\": \"Dinner from Swiggy\",\n  \"date\": \"2024-03-15\",\n  \"category_id\": 1\n}"
            }
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": "{{BASE_URL}}/api/expenses/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Zomato Order\",\n  \"amount\": 350.00\n}"
            }
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/expenses/1"
          }
        }
      ]
    },
    {
      "name": "Summary / Analytics",
      "item": [
        {
          "name": "Total Spending (All Time)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/summary/total"
          }
        },
        {
          "name": "Total Spending (Month Filter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/summary/total?month=3&year=2024",
              "query": [
                { "key": "month", "value": "3" },
                { "key": "year", "value": "2024" }
              ]
            }
          }
        },
        {
          "name": "Spending by Category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/summary/by-category"
          }
        },
        {
          "name": "Monthly Summary (Year)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/summary/monthly?year=2024",
              "query": [{ "key": "year", "value": "2024" }]
            }
          }
        }
      ]
    }
  ]
}
